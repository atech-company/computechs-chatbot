# Branding (shown in the chat header)
NEXT_PUBLIC_SITE_NAME=ComputechsLeb

# WhatsApp (optional): digits only with country code, e.g. 96170123456 — prefills quotation text to this chat via wa.me
# If omitted, WhatsApp still opens with prefilled text (user picks contact).
NEXT_PUBLIC_WHATSAPP_NUMBER=

# OpenAI
OPENAI_API_KEY=

# Optional override (defaults to gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# WooCommerce REST API (server-side only — never expose keys to the browser)
WOOCOMMERCE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Optional: restrict Next/Image hosts (comma-separated)
# NEXT_PUBLIC_STORE_IMAGE_HOSTS=your-store.com

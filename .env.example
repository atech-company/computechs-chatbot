# =============================================================================
# Copy to .env.local (local) or set in your host panel (production).
# Never commit real secrets. Never paste API keys into chat or public repos.
# =============================================================================

# --- Public / browser-safe (NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SITE_NAME=ComputechsLeb

# WhatsApp (digits + country code, no +). Used for wa.me links in the UI and store order alerts fallback.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Contact cards when user asks for WhatsApp / email / location in chat
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_STORE_ADDRESS=
# URL-encoded query is fine, e.g. https://maps.google.com/?q=Your+Street+City
NEXT_PUBLIC_STORE_MAP_URL=

# Optional: site URL for links in notification text (if WOOCOMMERCE_URL is not set)
# NEXT_PUBLIC_SITE_URL=https://your-site.com

# Optional: restrict Next/Image hosts (comma-separated)
# NEXT_PUBLIC_STORE_IMAGE_HOSTS=your-store.com

# --- OpenAI ---
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- WooCommerce REST (server only — never expose to the browser) ---
WOOCOMMERCE_URL=https://your-store.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Fallback billing email when chat order has no valid customer email (WooCommerce requires one)
WOOCOMMERCE_CHAT_ORDER_EMAIL=orders@your-store.com

# --- Order notifications (after ACTION flow creates a WooCommerce order) ---

# Resend — https://resend.com
RESEND_API_KEY=
ORDER_NOTIFY_FROM_EMAIL=noreply@your-verified-domain.com
ORDER_NOTIFY_FROM_NAME=ComputechsLeb
# Internal inbox for “new order” emails (defaults to WOOCOMMERCE_CHAT_ORDER_EMAIL if empty)
ORDER_NOTIFY_STORE_EMAIL=
# Optional: when shop WhatsApp fails, append a short Wasender error line to the chat reply (omit on fully public storefronts)
# ORDER_NOTIFY_DEBUG_IN_CHAT=true

# WhatsApp delivery: use Wasender OR Meta Cloud — if WASENDER_API_KEY is set, Wasender wins.

# WasenderAPI — https://wasenderapi.com/api-docs
# Free trial limit is typically 1 message/minute — the shop alert is auto-retried in the background after Wasender’s retry_after to avoid blocking chat. Upgrade for higher throughput.
# Auth: Authorization: Bearer <WASENDER_API_KEY>
WASENDER_API_KEY=
# Default: https://www.wasenderapi.com/api/send-message
WASENDER_API_URL=

# Wasender: wait between customer vs store WhatsApp (ms). Default 3500. Raise to 5000–8000 if the 2nd message drops.
# WASENDER_BETWEEN_MESSAGES_MS=3500
# Retry delay after a failed Wasender send (ms). Default 3500. Also reads WASENDER_CUSTOMER_RETRY_DELAY_MS if set.
# WASENDER_RETRY_DELAY_MS=3500

# If you add a Wasender webhook route, compare incoming X-Webhook-Signature to this value (server only).
WASENDER_WEBHOOK_SECRET=

# Meta WhatsApp Cloud API (only if Wasender is not used)
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v21.0

# Store WhatsApp for order alerts (digits + country code, no spaces). Strongly recommended on the server:
WHATSAPP_STORE_RECIPIENT=
# Same as above — server-only alias (works even if NEXT_PUBLIC_* was missing at build time)
STORE_WHATSAPP_NUMBER=
# Optional alias for Wasender setups
WASENDER_STORE_WHATSAPP=
# Wasender only: if shop alerts fail when WHATSAPP_STORE_RECIPIENT is the *same* as the linked session, set one of:
# - WASENDER_STORE_TO=+9617… (another staff phone), or
# - WHATSAPP_STORE_GROUP_JID=…@g.us (staff group; Wasender linked account must be in the group). Get JIDs via GET https://www.wasenderapi.com/api/groups
#   If your host truncates @, quote the value or use %40g.us (e.g. 120363…%40g.us)
WASENDER_STORE_TO=
WHATSAPP_STORE_GROUP_JID=
# Set to "false" to skip WhatsApp to the customer (store still notified if configured)
WHATSAPP_NOTIFY_CUSTOMER=true

# --- Hosting / dev ---
# Set to "true" only if HTTPS redirect middleware breaks local/staging proxies
# DISABLE_HTTPS_REDIRECT=true
